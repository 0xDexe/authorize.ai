# ── LLM Provider ──
AUTHORIZEAI_LLM_PROVIDER=anthropic   # "anthropic" or "openai"

# Anthropic (Claude)
ANTHROPIC_API_KEY=sk-ant-xxxxx
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# OpenAI (fallback)
# OPENAI_API_KEY=sk-xxxxx
# OPENAI_MODEL=gpt-4o-mini

# ── Retrieval ──
BM25_TOP_K=5

# ── Prediction ──
PREDICTION_MODEL=logistic   # "logistic" or "gbm"
# Optional: absolute path to a pre-trained model file (overrides data/models/approval_model.pkl)
# APPROVAL_MODEL_PATH=/path/to/approval_model.pkl

# ── Cloudflare Workers AI (free — no credit card required) ──
# Sign up at https://dash.cloudflare.com → AI → Workers AI
# CLOUDFLARE_ACCOUNT_ID=xxxxx
# CLOUDFLARE_API_TOKEN=xxxxx
# CLOUDFLARE_MODEL=@cf/meta/llama-3.1-8b-instruct

# ── Ollama (local or self-hosted) ──
# Install Ollama from https://ollama.com, then run: ollama pull llama3.2
# For a remote Ollama server, set OLLAMA_HOST to its address
# AUTHORIZEAI_LLM_PROVIDER=ollama
# OLLAMA_MODEL=llama3.2
# OLLAMA_HOST=http://localhost:11434

# ── LangSmith Tracing (optional) ──
# Sign up at https://smith.langchain.com and create an API key
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=ls__xxxxx
LANGCHAIN_PROJECT=authorize-ai

# ── Langfuse Tracing — free open-source alternative to LangSmith (optional) ──
# Sign up at https://cloud.langfuse.com or self-host
# LANGFUSE_PUBLIC_KEY=pk-lf-xxxxx
# LANGFUSE_SECRET_KEY=sk-lf-xxxxx
# LANGFUSE_HOST=https://us.cloud.langfuse.com
