# ── LLM Provider ──
AUTHORIZEAI_LLM_PROVIDER=anthropic   # "anthropic" or "openai"

# Anthropic (Claude)
ANTHROPIC_API_KEY=sk-ant-xxxxx
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# OpenAI (fallback)
# OPENAI_API_KEY=sk-xxxxx
# OPENAI_MODEL=gpt-4o-mini

# ── Retrieval ──
BM25_TOP_K=5

# ── Prediction ──
PREDICTION_MODEL=logistic   # "logistic" or "gbm"
